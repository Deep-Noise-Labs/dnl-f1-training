# Copy to train_task.env and edit (do not commit secrets).
# Used by scripts/clearml/train_f1_gpu4.sh

# --- Data & checkpoints (local paths on this server) ---
PRE_ENCODED_PATH=/data/aisynth_datasets/pre_encoded/f1_instrs_C3_midasheng
PRETRAINED_CKPT_PATH=/data/checkpoints/stable-audio-open-1.0.ckpt
MODEL_CONFIG=/data/repos/dnl-f1-training/models/foundation1_3s/model_config_3s.json
SAVE_DIR=/data/checkpoints/f1_3s_local

# --- Training (tune for H100 80GB — raise batch until ~70–75 GB VRAM used) ---
BATCH_SIZE=128
NUM_WORKERS=16
PRECISION=16-mixed
CHECKPOINT_EVERY=5000
# Each F1 checkpoint is ~15 GB. ModelCheckpoint keeps only the last N (+ save_last).
export CHECKPOINT_SAVE_TOP_K="${CHECKPOINT_SAVE_TOP_K:-2}"
# Temp files (ClearML artifact zip, runtime JSON) — use /data, not root /tmp.
export TMPDIR="${TMPDIR:-/data/tmp}"
ACCUM_BATCHES=1
SEED=42

# --- ClearML (credentials often in ~/.clearml.conf; override here if needed) ---
# CLEARML_API_HOST=https://api.your-clearml.example
# CLEARML_API_ACCESS_KEY=
# CLEARML_API_SECRET_KEY=
CLEARML_PROJECT="AI Synthesizer"
# CLEARML_TASK_NAME=f1-instrs-gpu4-manual

# --- GPU pin (physical index on 8×GPU host) ---
CUDA_VISIBLE_DEVICES=4

# --- Logging ---
USE_WANDB=0
